<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>403 Forbidden</title>
    <link rel="stylesheet" href="static/css/style.css" />
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body>
    <div class="container main-content error-container">
      <div class="error-code status-403">403</div>
      <div class="error-message">Access Denied / Forbidden</div>
      <p class="mb-30">
        You do not have permission to access this page based on your current
        role.
      </p>
      <a href="./" class="btn">Return to Home</a>
    </div>
  </body>
</html>


